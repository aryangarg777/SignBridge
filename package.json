{
    "name": "signbridge",
    "version": "1.0.0",
    "description": "AI Sign Language Communication Bridge",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "python-app": "source .venv/bin/activate && python app.py",
        "dev": "concurrently \"npm run python-app\" \"node server.js\""
    },
    "dependencies": {
        "dotenv": "^17.3.1",
        "express": "^4.21.1",
        "express-openid-connect": "^2.19.4",
        "http-proxy-middleware": "^3.0.3",
        "socket.io": "^4.8.1"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
